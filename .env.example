# Compliance Pilot — example environment configuration.
# Copy to `.env` (or export these) and adjust. Never commit your real .env.

# ---- Deployment ----
APP_ENV=development                       # set "production" to enforce a strong JWT secret

# ---- Auth ----
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
COOKIE_SECURE=false                       # true behind HTTPS in production
COOKIE_SAMESITE=lax

# ---- Web ----
CORS_ORIGINS=http://localhost:5173        # comma-separated allowed origins
MAX_UPLOAD_MB=100

# ---- LLM provider ----
LLM_PROVIDER=claude_code                  # "claude_code" (local CLI) or "ollama"
OLLAMA_URL=http://localhost:11434
LLM_MODEL=llama3.2

# ---- Embeddings ----
EMBED_MODEL=qwen3-embedding:8b
EMBED_URL=                                # empty = use OLLAMA_URL
EMBED_CONCURRENCY=1

# ---- Vector store / DB ----
QDRANT_URL=http://localhost:6333
DATABASE_URL=sqlite+aiosqlite:///./compliance.db

# ---- Retrieval tuning ----
CONFIDENCE_AUTO_FILL=0.82
CONFIDENCE_FLAG=0.65
MAX_CHUNKS=5
HYBRID_ALPHA=0.5
MAX_CHUNK_CHARS=1000
CHUNK_OVERLAP=150
QUERY_EXPANSION_ENABLED=true
RERANKING_ENABLED=true
INGESTION_TIMEOUT=600

# Optional: expand bare KB-article permalink slugs into full URLs
# KB_ARTICLE_URL_BASE=https://help.example.com/kb

# Allowlisted hosts for admin-settable Ollama/embed URLs (SSRF guard)
# SSRF_HOST_ALLOWLIST=localhost,127.0.0.1,::1
